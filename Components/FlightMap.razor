@using FlightApp.Domain
@using Microsoft.JSInterop
@implements IAsyncDisposable

@inject IJSRuntime JS

<div class="flight-map-root">
    @if (mapPoints.Count == 0)
    {
        <div class="flight-map-empty" style="@($"height:{Height};")">
            No track available
        </div>
    }
    else
    {
        <div id="@mapId" class="flight-map-surface" style="@($"height:{Height};")"></div>
    }
</div>


@code {
    [Parameter]
    public TrackArrays? Track { get; set; }

    [Parameter]
    public string Height { get; set; } = "100%";

    private readonly string mapId = $"flight-map-{Guid.NewGuid():N}";
    private readonly List<MapPointDto> mapPoints = new();

    private string? lastRenderSignature;
    private bool disposed;

    protected override void OnParametersSet()
    {
        mapPoints.Clear();

        if (Track?.LatE7 is null || Track.LonE7 is null)
            return;

        if (Track.LatE7.Length == 0 || Track.LonE7.Length == 0)
            return;

        var count = Math.Min(Track.LatE7.Length, Track.LonE7.Length);

        for (var i = 0; i < count; i++)
        {
            var lat = Track.LatE7[i] / 10_000_000.0;
            var lng = Track.LonE7[i] / 10_000_000.0;

            if (lat is < -90 or > 90 || lng is < -180 or > 180)
                continue;

            mapPoints.Add(new MapPointDto
            {
                Lat = lat,
                Lng = lng
            });
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (disposed)
            return;

        if (mapPoints.Count == 0)
        {
            if (lastRenderSignature is not null)
            {
                await JS.InvokeVoidAsync("flightMapComponent.clear", mapId);
                lastRenderSignature = null;
            }

            return;
        }

        var signature = BuildRenderSignature();

        if (signature == lastRenderSignature)
            return;

        await JS.InvokeVoidAsync("flightMapComponent.render", mapId, mapPoints);
        lastRenderSignature = signature;
    }

    public async ValueTask DisposeAsync()
    {
        if (disposed)
            return;

        disposed = true;

        try
        {
            await JS.InvokeVoidAsync("flightMapComponent.dispose", mapId);
        }
        catch
        {
        }
    }

    private string BuildRenderSignature()
    {
        var first = mapPoints[0];
        var last = mapPoints[^1];

        return $"{mapPoints.Count}:{first.Lat:F7}:{first.Lng:F7}:{last.Lat:F7}:{last.Lng:F7}";
    }

    private sealed class MapPointDto
    {
        public double Lat { get; set; }
        public double Lng { get; set; }
    }
}