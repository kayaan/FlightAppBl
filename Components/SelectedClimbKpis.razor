@using FlightApp.Analysis
@using FlightApp.Domain
@using FlightApp.Components

@if (Stats is not null && SelectedClimb is not null)
{
    <div class="ux-kpi-container">
        <KpiTile Title="Begin / End"
                 Meta="Relative flight time"
                 Value="@BeginEndText" />

        <KpiTile Title="Duration"
                 Meta="Selected climb"
                 Value="@DisplayedDurationText" />

        <KpiTile Title="Distance"
                 Meta="@($"Fixes {Stats.FixCount}")"
                 Value="@FlightDetailsFormatters.FormatDistanceKm(Stats.TotalDistanceMeters)" />

        <KpiTile Title="Altitude"
                 Meta="min/max"
                 Value="@FlightDetailsFormatters.FormatAltitudeMinMaxPreferred(Stats)" />

        <KpiTile Title="Vario"
                 Meta="min/max/avg"
                 Value="@FlightDetailsFormatters.FormatVario(Stats, SelectedClimb)" />

        <KpiTile Title="Speed"
                 Meta="avg/max"
                 Value="@FlightDetailsFormatters.FormatSpeedAvgMax(Stats)" />

        <KpiTile Title="Gain"
                 Meta="Net climb"
                 Value="@FlightDetailsFormatters.FormatGain(SelectedClimb)" />
    </div>
}

@code {
    [Parameter] public FlightStats? Stats { get; set; }
    [Parameter] public ClimbSegment? SelectedClimb { get; set; }
    [Parameter] public TrackArrays? TrackArrays { get; set; }

    private string BeginEndText
    {
        get
        {
            if (SelectedClimb is null || TrackArrays?.TimeSec is null)
                return "— / —";

            var begin = GetTrackTimeSeconds(SelectedClimb.BeginIndex);
            var end = GetTrackTimeSeconds(SelectedClimb.EndIndex);

            return $"{FlightDetailsFormatters.FormatClockFromSeconds(begin)} / {FlightDetailsFormatters.FormatClockFromSeconds(end)}";
        }
    }

    private string DisplayedDurationText
    {
        get
        {
            if (SelectedClimb is null || TrackArrays?.TimeSec is null)
                return "—";

            var begin = GetTrackTimeSeconds(SelectedClimb.BeginIndex);
            var end = GetTrackTimeSeconds(SelectedClimb.EndIndex);
            var durationSeconds = Math.Max(0, end - begin);

            return FlightDetailsFormatters.FormatClockFromSeconds(durationSeconds);
        }
    }

    private int GetTrackTimeSeconds(int index)
    {
        if (TrackArrays?.TimeSec is null || TrackArrays.TimeSec.Length == 0)
            return 0;

        if (index < 0)
            return 0;

        if (index >= TrackArrays.TimeSec.Length)
            index = TrackArrays.TimeSec.Length - 1;

        return TrackArrays.TimeSec[index];
    }
}