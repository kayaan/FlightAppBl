@namespace FlightApp.Components

@using FlightApp.Domain
@using Microsoft.JSInterop
@implements IAsyncDisposable

@inject IJSRuntime JS

<div class="flight-map-root">
    @if (!HasTrackPoints)
    {
        <div class="flight-map-empty" style="@($"height:{Height};")">
            No track available
        </div>
    }
    else
    {
        <div id="@mapId" class="flight-map-surface" style="@($"height:{Height};")"></div>
    }
</div>

@code {
    [Parameter]
    public TrackArrays? Track { get; set; }

    [Parameter]
    public string Height { get; set; } = "100%";

    private readonly string mapId = $"flight-map-{Guid.NewGuid():N}";
    private string? lastRenderSignature;
    private bool disposed;

    private bool HasTrackPoints =>
        Track?.LatE7 is { Length: > 0 } &&
        Track.LonE7 is { Length: > 0 };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (disposed)
            return;

        if (!HasTrackPoints)
        {
            if (lastRenderSignature is not null)
            {
                await JS.InvokeVoidAsync("flightMapComponent.clear", mapId);
                lastRenderSignature = null;
            }

            return;
        }

        var signature = BuildRenderSignature();

        if (signature == lastRenderSignature)
            return;

        var timeSec = BuildTimeSec();

        await JS.InvokeVoidAsync(
            "flightMapComponent.renderTrackArrays",
            mapId,
            timeSec,
            Track!.LatE7,
            Track.LonE7);

        lastRenderSignature = signature;
    }

    private double[] BuildTimeSec()
    {
        var deltas = Track?.TDeltaMs;
        if (deltas is null || deltas.Length == 0)
            return Array.Empty<double>();

        var result = new double[deltas.Length];
        long sumMs = 0;

        for (int i = 0; i < deltas.Length; i++)
        {
            sumMs += deltas[i];
            result[i] = sumMs / 1000.0;
        }

        return result;
    }

    public async ValueTask DisposeAsync()
    {
        if (disposed)
            return;

        disposed = true;

        try
        {
            await JS.InvokeVoidAsync("flightMapComponent.dispose", mapId);
        }
        catch
        {
        }
    }

    private string BuildRenderSignature()
    {
        var latE7 = Track!.LatE7;
        var lonE7 = Track!.LonE7;

        var count = Math.Min(latE7.Length, lonE7.Length);

        if (count == 0)
            return "0";

        return $"{count}:{latE7[0]}:{lonE7[0]}:{latE7[count - 1]}:{lonE7[count - 1]}";
    }
}