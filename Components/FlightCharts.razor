@namespace FlightApp.Components

@using FlightApp.Analysis
@using FlightApp.Domain
@using Microsoft.JSInterop

@implements IAsyncDisposable

@inject IJSRuntime JS

<div class="flight-charts-root">
    @if (!HasTrack)
    {
        <div class="flight-charts-empty">
            No chart data available
        </div>
    }
    else
    {
        <div id="@altChartId" class="chart-panel"></div>
        <div id="@varioChartId" class="chart-panel"></div>
        <div id="@speedChartId" class="chart-panel"></div>
    }
</div>

@code {
    [Parameter]
    public TrackArrays? Track { get; set; }

    [Parameter]
    public ClimbSegment? SelectedClimb { get; set; }

    private readonly string altChartId = $"chart-alt-{Guid.NewGuid():N}";
    private readonly string varioChartId = $"chart-vario-{Guid.NewGuid():N}";
    private readonly string speedChartId = $"chart-speed-{Guid.NewGuid():N}";

    private bool disposed;

    private string? lastDataSignature;

    private string? lastClimbSignature;

    private bool HasTrack =>
        Track?.TDeltaMs is { Length: > 1 };


    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (disposed)
            return;

        if (!HasTrack)
        {
            if (lastDataSignature is not null)
            {
                await JS.InvokeVoidAsync("flightCharts.dispose", altChartId);
                await JS.InvokeVoidAsync("flightCharts.dispose", varioChartId);
                await JS.InvokeVoidAsync("flightCharts.dispose", speedChartId);

                lastDataSignature = null;
                lastClimbSignature = null;
            }

            return;
        }

        var dataSignature = BuildDataSignature();
        if (dataSignature != lastDataSignature)
        {
            var payload = BuildBasePayload();
            if (payload is null)
                return;

            await JS.InvokeVoidAsync(
                "flightCharts.renderAll",
                altChartId,
                varioChartId,
                speedChartId,
                payload);

            lastDataSignature = dataSignature;
            lastClimbSignature = null;
        }

        var climbSignature = BuildClimbSignature();
        if (climbSignature != lastClimbSignature)
        {
            var climbPayload = BuildSelectedClimbPayload();

            await JS.InvokeVoidAsync(
                "flightCharts.updateSelectedClimb",
                altChartId,
                varioChartId,
                speedChartId,
                climbPayload);

            lastClimbSignature = climbSignature;
        }
    }

    private string BuildDataSignature()
    {
        var t = Track!.TDeltaMs;
        var count = t.Length;

        var alt = SelectAltitudeSource();
        var speed = Track.SpeedCms;
        var vario = Track.VarioCms;

        var altLen = alt?.Length ?? 0;
        var speedLen = speed?.Length ?? 0;
        var varioLen = vario?.Length ?? 0;

        return $"{count}:{altLen}:{speedLen}:{varioLen}:{t[0]}:{t[count - 1]}";
    }

    private string BuildClimbSignature()
    {
        var selectedBegin = SelectedClimb?.BeginIndex ?? -1;
        var selectedEnd = SelectedClimb?.EndIndex ?? -1;

        return $"{selectedBegin}:{selectedEnd}";
    }

    public async ValueTask DisposeAsync()
    {
        if (disposed)
            return;

        disposed = true;

        try
        {
            await JS.InvokeVoidAsync("flightCharts.dispose", altChartId);
            await JS.InvokeVoidAsync("flightCharts.dispose", varioChartId);
            await JS.InvokeVoidAsync("flightCharts.dispose", speedChartId);
        }
        catch
        {
        }
    }


    private FlightChartsPayload? BuildBasePayload()
    {
        if (Track?.TDeltaMs is not { Length: > 1 } tDeltaMs)
            return null;

        return new FlightChartsPayload
        {
            TimeSec = BuildTimeSeconds(tDeltaMs),

            AltitudeTitle = "Altitude",
            AltitudeUnit = "m",
            AltitudeValues = BuildScaledSeries(SelectAltitudeSource(), 0.01),

            VarioTitle = "Vario",
            VarioUnit = "m/s",
            VarioValues = BuildScaledSeries(Track.VarioCms, 0.01),

            SpeedTitle = "Speed",
            SpeedUnit = "km/h",
            SpeedValues = BuildScaledSeries(Track.SpeedCms, 0.036)
        };
    }

    private SelectedClimbPayload BuildSelectedClimbPayload()
    {
        return new SelectedClimbPayload
        {
            SelectedClimbBeginIndex = SelectedClimb?.BeginIndex,
            SelectedClimbEndIndex = SelectedClimb?.EndIndex
        };
    }


    private FlightChartsPayload? BuildPayload()
    {
        if (Track?.TDeltaMs is not { Length: > 1 } tDeltaMs)
            return null;

        return new FlightChartsPayload
        {
            TimeSec = BuildTimeSeconds(tDeltaMs),

            AltitudeTitle = "Altitude",
            AltitudeUnit = "m",
            AltitudeValues = BuildScaledSeries(SelectAltitudeSource(), 0.01),

            VarioTitle = "Vario",
            VarioUnit = "m/s",
            VarioValues = BuildScaledSeries(Track.VarioCms, 0.01),

            SpeedTitle = "Speed",
            SpeedUnit = "km/h",
            SpeedValues = BuildScaledSeries(Track.SpeedCms, 0.036),

            SelectedClimbBeginIndex = SelectedClimb?.BeginIndex,
            SelectedClimbEndIndex = SelectedClimb?.EndIndex
        };
    }

    private static double[] BuildTimeSeconds(int[] tDeltaMs)
    {
        var count = tDeltaMs.Length;
        var result = new double[count];

        double totalMs = 0;
        for (var i = 0; i < count; i++)
        {
            totalMs += tDeltaMs[i];
            result[i] = totalMs / 1000.0;
        }

        return result;
    }

    private static double[]? BuildScaledSeries(int[]? source, double scale)
    {
        if (source is null || source.Length == 0)
            return null;

        var result = new double[source.Length];
        for (var i = 0; i < source.Length; i++)
        {
            result[i] = source[i] * scale;
        }

        return result;
    }

    private int[]? SelectAltitudeSource()
    {
        if (Track?.AltBaroCm is { Length: > 0 })
            return Track.AltBaroCm;

        if (Track?.AltGpsCm is { Length: > 0 })
            return Track.AltGpsCm;

        return null;
    }

    private string BuildSignature()
    {
        var t = Track!.TDeltaMs;
        var count = t.Length;

        var alt = SelectAltitudeSource();
        var speed = Track.SpeedCms;
        var vario = Track.VarioCms;

        var altLen = alt?.Length ?? 0;
        var speedLen = speed?.Length ?? 0;
        var varioLen = vario?.Length ?? 0;

        var selectedBegin = SelectedClimb?.BeginIndex ?? -1;
        var selectedEnd = SelectedClimb?.EndIndex ?? -1;

        return $"{count}:{altLen}:{speedLen}:{varioLen}:{t[0]}:{t[count - 1]}:{selectedBegin}:{selectedEnd}";
    }
}