@* Pages\FlightList.razor *@

@page "/"
@page "/flights"

@using FlightApp.Components
@using FlightApp.Domain
@using FlightApp.Services
@using Microsoft.AspNetCore.Components.Forms

@inject IJSRuntime JS
@inject FlightService FlightService
@inject IKeyValueStorage KeyValueStorage
@inject ToastService ToastService
@inject FlightImportStateService ImportState
@inject NavigationManager Nav

@implements IDisposable

<PageTitle>Flights</PageTitle>

<div class="flights-page">
    <div class="flights-header">
        <div>
            <h1 class="page-title">Flights</h1>
            <p class="page-subtitle">Imported IGC flights with the most relevant stats.</p>
        </div>


        @if (ImportState.State.IsImporting)
        {
            <div class="import-progress">
                <div class="import-progress-title">
                    Importing @ImportState.State.ProcessedFiles of @ImportState.State.TotalFiles files
                </div>

                @if (!string.IsNullOrWhiteSpace(ImportState.State.CurrentFileName))
                {
                    <div class="import-progress-file">
                        @ImportState.State.CurrentFileName
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(ImportState.State.CurrentMessage))
                {
                    <div class="import-progress-message">
                        @ImportState.State.CurrentMessage
                    </div>
                }

                <div class="import-progress-stats">
                    <span>Imported: @ImportState.State.ImportedCount</span>
                    <span>Duplicates: @ImportState.State.DuplicateCount</span>
                    <span>Failed: @ImportState.State.FailedCount</span>
                </div>

                <div class="progress-bar">
                    <div class="progress-fill" style="width:@(ImportState.State.TotalFiles > 0
                        ? ImportState.State.ProcessedFiles * 100.0 / ImportState.State.TotalFiles
                        : 0)%">
                    </div>
                </div>
            </div>
        }

        <button class="import-button"        @onclick="OpenImport"        disabled="@ImportState.State.IsImporting">
            @(ImportState.State.IsImporting ? "Importing..." : "Import IGC")
        </button>

    </div>

    <InputFile @ref="fileInput" OnChange="HandleFileSelected" style="display: none;" accept=".igc" multiple />

    @if (flights.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-icon">🪂</div>
            <div class="empty-title">No flights imported yet</div>
            <div class="empty-text">Import one or more IGC files to see your flight list.</div>
        </div>
    }
    else
    {
        <div class="table-card">
            <div class="table-scroll">
                <table class="flights-table">
                    <thead>
                        <tr>
                            <th class="sortable @(sortColumn == FlightSortColumn.Date ? "active" : null)"
                                @onclick="async () => await SortBy(FlightSortColumn.Date)">
                                <span class="th-content">
                                    <span>Date</span>
                                    <span class="sort-icon">@SortIndicator(FlightSortColumn.Date)</span>
                                </span>
                            </th>

                            <th class="sortable @(sortColumn == FlightSortColumn.Start ? "active" : null)"
                                @onclick="async () => await SortBy(FlightSortColumn.Start)">
                                <span class="th-content">
                                    <span>Start</span>
                                    <span class="sort-icon">@SortIndicator(FlightSortColumn.Start)</span>
                                </span>
                            </th>

                            <th class="sortable @(sortColumn == FlightSortColumn.Pilot ? "active" : null)"
                                @onclick="async () => await SortBy(FlightSortColumn.Pilot)">
                                <span class="th-content">
                                    <span>Pilot</span>
                                    <span class="sort-icon">@SortIndicator(FlightSortColumn.Pilot)</span>
                                </span>
                            </th>

                            <th class="sortable @(sortColumn == FlightSortColumn.Glider ? "active" : null)"
                                @onclick="async () => await SortBy(FlightSortColumn.Glider)">
                                <span class="th-content">
                                    <span>Glider</span>
                                    <span class="sort-icon">@SortIndicator(FlightSortColumn.Glider)</span>
                                </span>
                            </th>

                            <th class="num sortable @(sortColumn == FlightSortColumn.Duration ? "active" : null)"
                                @onclick="async () => await SortBy(FlightSortColumn.Duration)">
                                <span class="th-content">
                                    <span>Duration</span>
                                    <span class="sort-icon">@SortIndicator(FlightSortColumn.Duration)</span>
                                </span>
                            </th>

                            <th class="num sortable @(sortColumn == FlightSortColumn.Distance ? "active" : null)"
                                @onclick="async () => await SortBy(FlightSortColumn.Distance)">
                                <span class="th-content">
                                    <span>Distance</span>
                                    <span class="sort-icon">@SortIndicator(FlightSortColumn.Distance)</span>
                                </span>
                            </th>

                            <th class="num sortable @(sortColumn == FlightSortColumn.Altitude ? "active" : null)"
                                @onclick="async () => await SortBy(FlightSortColumn.Altitude)">
                                <span class="th-content">
                                    <span>Altitude</span>
                                    <span class="sort-icon">@SortIndicator(FlightSortColumn.Altitude)</span>
                                </span>
                            </th>

                            <th class="num sortable @(sortColumn == FlightSortColumn.Climb ? "active" : null)"
                                @onclick="async () => await SortBy(FlightSortColumn.Climb)">
                                <span class="th-content">
                                    <span>Climb</span>
                                    <span class="sort-icon">@SortIndicator(FlightSortColumn.Climb)</span>
                                </span>
                            </th>

                            <th class="actions">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var flight in GetSortedFlights())
                        {
                            <tr class="flight-row" @onclick="() => OpenFlight(flight.Id)">
                                <td>
                                    <div class="main-value">@FormatDate(flight)</div>
                                </td>

                                <td>
                                    <div class="main-value">@FormatStartTime(flight.Stats.StartTimeUtc)</div>
                                </td>

                                <td>
                                    <div class="main-value">@NullOrDash(flight.PilotId)</div>
                                </td>

                                <td>
                                    <div class="main-value">@NullOrDash(flight.GliderId)</div>
                                </td>

                                <td class="num">
                                    <div class="main-value">@FormatDuration(flight.Stats.Duration)</div>
                                </td>

                                <td class="num">
                                    <div class="main-value">@FormatDistanceKm(flight.Stats.TotalDistanceMeters)</div>
                                </td>

                                <td class="num">
                                    <div class="alt-pair">
                                        <span                            class="alt-num">@FormatAltitudeNumber(GetPreferredMaxAltitude(flight.Stats))</span>
                                        <span class="alt-sep">/</span>
                                        <span                            class="alt-num">@FormatAltitudeNumber(GetPreferredMinAltitude(flight.Stats))</span>
                                        <span class="alt-unit">m</span>
                                    </div>
                                </td>

                                <td class="num">
                                    <div class="climb-pair">
                                        <span class="climb-num">@FormatClimbNumber(flight.Stats.MaxVarioMs)</span>
                                        <span class="climb-sep">/</span>
                                        <span class="climb-num">@FormatClimbNumber(flight.Stats.MinVarioMs)</span>
                                        <span class="climb-unit">m/s</span>
                                    </div>
                                </td>

                                <td class="actions-cell">
                                    <div class="action-group">
                                        <button class="table-action table-action-open" title="Open flight"
                                                @onclick="() => OpenFlight(flight.Id)" @onclick:stopPropagation="true">
                                            Open
                                        </button>

                                        <button class="table-action table-action-delete" title="Delete flight"
                                                @onclick="() => OnDeleteClick(flight.Id)" @onclick:stopPropagation="true">
                                            Delete
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private InputFile? fileInput;
    private List<Flight> flights = new();

    private FlightSortColumn sortColumn = FlightSortColumn.Date;
    private bool sortDescending = true;

    protected override async Task OnInitializedAsync()
    {
        ImportState.OnChange += HandleImportStateChanged;

        flights = await FlightService.GetFlightsAsync();

        var state = await KeyValueStorage.GetOrDefaultAsync(
            AppStorageKeys.FlightsTableState,
            new FlightsTableState());

        if (Enum.TryParse<FlightSortColumn>(state.SortColumn, ignoreCase: true, out var parsedColumn))
        {
            sortColumn = parsedColumn;
        }

        sortDescending = state.SortDescending;
    }

    private void HandleImportStateChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ImportState.OnChange -= HandleImportStateChanged;
    }

    private async Task OpenImport()
    {
        if (fileInput is not null)
        {
            await JS.InvokeVoidAsync("openFilePicker", fileInput.Element);
        }
    }

    private async Task OnDeleteClick(string id)
    {
        @* var confirm = await JS.InvokeAsync<bool>("confirm", "Delete this flight?");
        if (!confirm)
            return;

             *@

        await FlightService.DeleteFlightAsync(id);
        flights = await FlightService.GetFlightsAsync();
    }

    private void OpenFlight(string id)
    {
        if (string.IsNullOrWhiteSpace(id))
            return;

        Nav.NavigateTo($"/flights/{id}");
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        IReadOnlyList<IBrowserFile>? files = e.GetMultipleFiles(100);

        await FlightService.ImportAndSaveAsync(files);

        flights = await FlightService.GetFlightsAsync();
    }


    private async Task SortBy(FlightSortColumn column)
    {

        if (sortColumn == column)
        {
            sortDescending = !sortDescending;
        }
        else
        {
            sortColumn = column;
            sortDescending = column switch
            {
                FlightSortColumn.Date => true,
                FlightSortColumn.Start => true,
                FlightSortColumn.Duration => true,
                FlightSortColumn.Distance => true,
                FlightSortColumn.Altitude => true,
                FlightSortColumn.Climb => true,
                _ => false
            };
        }

        await KeyValueStorage.SetAsync(
            AppStorageKeys.FlightsTableState,
            new FlightsTableState
            {
                SortColumn = sortColumn.ToString(),
                SortDescending = sortDescending
            });
    }

    private IEnumerable<Flight> GetSortedFlights()
    {
        IEnumerable<Flight> query = sortColumn switch
        {
            FlightSortColumn.Date => sortDescending
                ? flights.OrderByDescending(GetSortDateTime)
                : flights.OrderBy(GetSortDateTime),

            FlightSortColumn.Start => sortDescending
                ? flights.OrderByDescending(f => f.Stats.StartTimeUtc)
                : flights.OrderBy(f => f.Stats.StartTimeUtc),

            FlightSortColumn.Pilot => sortDescending
                ? flights.OrderByDescending(f => f.PilotId ?? string.Empty)
                : flights.OrderBy(f => f.PilotId ?? string.Empty),

            FlightSortColumn.Glider => sortDescending
                ? flights.OrderByDescending(f => f.GliderId ?? string.Empty)
                : flights.OrderBy(f => f.GliderId ?? string.Empty),

            FlightSortColumn.Duration => sortDescending
                ? flights.OrderByDescending(f => f.Stats.Duration)
                : flights.OrderBy(f => f.Stats.Duration),

            FlightSortColumn.Distance => sortDescending
                ? flights.OrderByDescending(f => f.Stats.TotalDistanceMeters)
                : flights.OrderBy(f => f.Stats.TotalDistanceMeters),

            FlightSortColumn.Altitude => sortDescending
                ? flights.OrderByDescending(f => GetPreferredMaxAltitude(f.Stats) ?? int.MinValue)
                : flights.OrderBy(f => GetPreferredMaxAltitude(f.Stats) ?? int.MinValue),

            FlightSortColumn.Climb => sortDescending
                ? flights.OrderByDescending(f => f.Stats.MaxVarioMs ?? double.MinValue)
                : flights.OrderBy(f => f.Stats.MaxVarioMs ?? double.MinValue),

            _ => flights.OrderByDescending(GetSortDateTime)
        };

        return query;
    }

    private static DateTime GetSortDateTime(Flight flight)
        => flight.Stats.StartTimeUtc ?? flight.CreatedAtUtc;

    private string SortIndicator(FlightSortColumn column)
    {
        if (sortColumn != column)
            return "⇅";

        return sortDescending ? "↓" : "↑";
    }

    private static string NullOrDash(string? value)
        => string.IsNullOrWhiteSpace(value) ? "—" : value;

    private static string FormatDate(Flight flight)
    {
        if (flight.Stats.StartTimeUtc.HasValue)
        {
            return flight.Stats.StartTimeUtc.Value.ToLocalTime().ToString("dd MMM yyyy");
        }

        return string.IsNullOrWhiteSpace(flight.Date) ? "—" : flight.Date;
    }

    private static string FormatStartTime(DateTime? timeUtc)
    {
        if (!timeUtc.HasValue)
            return "—";

        return timeUtc.Value.ToLocalTime().ToString("HH:mm");
    }

    private static string FormatDuration(TimeSpan duration)
    {
        if (duration.TotalHours >= 1)
            return $"{(int)duration.TotalHours}h {duration.Minutes}m";

        return $"{duration.Minutes}m";
    }

    private static string FormatDistanceKm(double totalDistanceMeters)
        => $"{totalDistanceMeters / 1000.0:0.0} km";

    private static int? GetPreferredMaxAltitude(FlightStats stats)
        => stats.AltBaroMax ?? stats.AltGpsMax;

    private static int? GetPreferredMinAltitude(FlightStats stats)
        => stats.AltBaroMin ?? stats.AltGpsMin;

    private static string FormatAltitudeNumber(int? value)
        => value.HasValue ? value.Value.ToString() : "—";

    private static string FormatClimbNumber(double? value)
    {
        if (!value.HasValue)
            return "—";

        return value.Value.ToString("+0.0;-0.0;0.0");
    }

    private enum FlightSortColumn
    {
        Date,
        Start,
        Pilot,
        Glider,
        Duration,
        Distance,
        Altitude,
        Climb
    }
}