@page "/flights/{Id}"

@using FlightApp.Analysis
@using FlightApp.Components
@using FlightApp.Domain
@using FlightApp.Services
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop

@implements IAsyncDisposable

@inject FlightService FlightService
@inject IJSRuntime JS

<div class="flight-details-page">
    @if (isLoading)
    {
        <div class="state-card">
            <div class="state-title">Loading flight…</div>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="state-card state-error">
            <div class="state-title">Could not load flight</div>
            <div class="state-text">@errorMessage</div>
        </div>
    }
    else if (flight is null)
    {
        <div class="state-card">
            <div class="state-title">Flight not found</div>
            <div class="state-text">No flight exists for the requested id.</div>
        </div>
    }
    else if (displayedStats is null)
    {
        <div class="state-card">
            <div class="state-title">Flight data incomplete</div>
            <div class="state-text">Statistics are not available.</div>
        </div>
    }
    else
    {
        <div class="flight-header">
            <div class="flight-kpis-top">
                <div class="hero-kpi @(currentSelection != null ? "hero-kpi-selection" : null)">
                    <div class="hero-kpi-label">Date / Time</div>
                    <div class="hero-kpi-value">@FormatDateTimeShort(displayedStats.StartTimeUtc)</div>
                    <div class="hero-kpi-sub">@NullOrDash(flight.PilotId)</div>
                </div>

                <div class="hero-kpi @(currentSelection != null ? "hero-kpi-selection" : null)">
                    <div class="hero-kpi-label">Duration</div>
                    <div class="hero-kpi-value">@FormatDuration(displayedStats.Duration)</div>
                    <div class="hero-kpi-sub">@NullOrDash(flight.GliderId)</div>
                </div>

                <div class="hero-kpi @(currentSelection != null ? "hero-kpi-selection" : null)">
                    <div class="hero-kpi-label">Distance</div>
                    <div class="hero-kpi-value">@FormatDistanceKm(displayedStats.TotalDistanceMeters)</div>
                    <div class="hero-kpi-sub">Fixes @displayedStats.FixCount</div>
                </div>

                <div class="hero-kpi @(currentSelection != null ? "hero-kpi-selection" : null)">
                    <div class="hero-kpi-label">Altitude</div>
                    <div class="hero-kpi-value">@FormatAltitudeMinMaxPreferred(displayedStats)</div>
                    <div class="hero-kpi-sub">Min / Max</div>
                </div>

                <div class="hero-kpi @(currentSelection != null ? "hero-kpi-selection" : null)">
                    <div class="hero-kpi-label">Vario</div>
                    <div class="hero-kpi-value">@FormatVarioMinMax(displayedStats)</div>
                    <div class="hero-kpi-sub">Min / Max</div>
                </div>

                <div class="hero-kpi @(currentSelection != null ? "hero-kpi-selection" : null)">
                    <div class="hero-kpi-label">Speed</div>
                    <div class="hero-kpi-value">@FormatSpeedAvgMax(displayedStats)</div>
                    <div class="hero-kpi-sub">Avg / Max</div>
                </div>

                <div class="hero-kpi @(currentSelection != null ? "hero-kpi-selection" : null)">
                    <div class="hero-kpi-label">Takeoff / Landing Elevation</div>
                    <div class="hero-kpi-value">
                        @FormatAltitudeValue(GetTakeoffHeight(displayedStats)) /
                        @FormatAltitudeValue(GetLandingHeight(displayedStats))
                    </div>
                    <div class="hero-kpi-sub">m (start / land)</div>
                </div>
            </div>
        </div>

        <div class="flight-layout" @ref="flightLayoutRef">
            <div class="left-pane" style="@GetLeftPaneStyle()">
                <FlightCharts Track="trackArrays" />
            </div>

            <div class="splitter @(isResizing ? "splitter-active" : null)" @onmousedown="StartResize"
                 @onmousedown:preventDefault="true" aria-label="Resize panels" role="separator">
            </div>

            <div class="right-pane">
                <FlightMap Track="trackArrays" Height="100%" />
            </div>
        </div>

        @if (isResizing)
        {
            <div class="resize-overlay"></div>
        }
    }
</div>

@code {
    [Parameter]
    public string? Id { get; set; }


    private readonly TrackSegmentStatsCalculator segmentStatsCalculator = new();

    private SelectionRange? currentSelection;
    private FlightStats? displayedStats;

    private Flight? flight;
    private TrackArrays? trackArrays;
    private bool isLoading;
    private string? errorMessage;

    private int leftPanePercent = 50;
    private bool isResizing;

    private ElementReference flightLayoutRef;
    private double layoutLeft;
    private double layoutWidth;

    private DotNetObjectReference<FlightDetails>? dotNetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        dotNetRef ??= DotNetObjectReference.Create(this);

        await JS.InvokeVoidAsync("flightCharts.registerSelectionCallback", dotNetRef);
    }

    [JSInvokable]
    public Task OnChartSelection(int startIndex, int endIndex)
    {
        ApplySelection(startIndex, endIndex);
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnChartSelectionCleared()
    {
        ClearSelection();
        return Task.CompletedTask;
    }

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        errorMessage = null;
        flight = null;
        trackArrays = null;

        try
        {
            if (string.IsNullOrWhiteSpace(Id))
            {
                errorMessage = "Missing flight id.";
                return;
            }

            flight = await FlightService.GetFlightByIdAsync(Id);
            trackArrays = await FlightService.GetTrackAsync(Id);

            displayedStats = flight?.Stats;
            currentSelection = null;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ApplySelection(int startIndex, int endIndex)
    {
        if (trackArrays is null)
            return;

        var selection = new SelectionRange(startIndex, endIndex);
        if (!selection.IsValid)
            return;

        currentSelection = selection;
        displayedStats = segmentStatsCalculator.Calculate(trackArrays, selection);

        StateHasChanged();
    }

    private void ClearSelection()
    {
        currentSelection = null;
        displayedStats = flight?.Stats;

        StateHasChanged();
    }

    private string GetLeftPaneStyle()
        => $"flex: 0 0 {leftPanePercent}%;";

    private async Task StartResize(MouseEventArgs _)
    {
        dotNetRef ??= DotNetObjectReference.Create(this);
        isResizing = true;
        await InvokeAsync(StateHasChanged);

        await JS.InvokeVoidAsync("flightDetails.startResize", flightLayoutRef, dotNetRef);
    }

    [JSInvokable]
    public Task SetResizeBounds(double left, double width)
    {
        layoutLeft = left;
        layoutWidth = width;
        return Task.CompletedTask;
    }

    [JSInvokable]
    public async Task OnResizeDrag(double clientX)
    {
        if (layoutWidth <= 0)
            return;

        var relativeX = clientX - layoutLeft;
        var newPercent = (int)Math.Round(relativeX / layoutWidth * 100.0);

        var clamped = Math.Clamp(newPercent, 30, 75);
        if (clamped == leftPanePercent)
            return;

        leftPanePercent = clamped;

        await InvokeAsync(StateHasChanged);
        await JS.InvokeVoidAsync("flightDetails.notifyResize");
    }

    [JSInvokable]
    public async Task OnResizeEnd()
    {
        isResizing = false;
        await InvokeAsync(StateHasChanged);
        await JS.InvokeVoidAsync("flightDetails.notifyResize");
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("flightCharts.clearSelectionCallback");
        }
        catch
        {
        }

        dotNetRef?.Dispose();
    }

    private static string NullOrDash(string? value)
        => string.IsNullOrWhiteSpace(value) ? "—" : value;

    private static string FormatDateTimeShort(DateTime? value)
    {
        if (!value.HasValue)
            return "—";

        return value.Value.ToLocalTime().ToString("dd MMM yyyy HH:mm");
    }

    private static string FormatDuration(TimeSpan duration)
    {
        if (duration.TotalHours >= 1)
            return $"{(int)duration.TotalHours}h {duration.Minutes}m";

        return $"{duration.Minutes}m";
    }

    private static string FormatDistanceKm(double totalDistanceMeters)
        => $"{totalDistanceMeters / 1000.0:0.0} km";

    private static string FormatAltitudeValue(int? value)
    {
        if (!value.HasValue)
            return "—";

        return $"{value.Value} m";
    }

    private static string FormatAltitudeMinMaxPreferred(FlightStats stats)
    {
        var min = stats.AltBaroMin ?? stats.AltGpsMin;
        var max = stats.AltBaroMax ?? stats.AltGpsMax;

        if (!min.HasValue && !max.HasValue)
            return "—";

        var minText = min.HasValue ? $"{min.Value}" : "—";
        var maxText = max.HasValue ? $"{max.Value}" : "—";

        return $"{minText} / {maxText} m";
    }

    private static string FormatVarioMinMax(FlightStats stats)
    {
        var min = stats.MinVarioMs;
        var max = stats.MaxVarioMs;

        if (!min.HasValue && !max.HasValue)
            return "—";

        var minText = min.HasValue ? $"{min.Value:0.0}" : "—";
        var maxText = max.HasValue ? $"{max.Value:0.0}" : "—";

        return $"{minText} / {maxText} m/s";
    }

    private static string FormatSpeedAvgMax(FlightStats stats)
    {
        var avgText = stats.AvgGroundSpeedKmh.HasValue ? $"{stats.AvgGroundSpeedKmh.Value:0.0}" : "—";
        var maxText = stats.MaxGroundSpeedKmh.HasValue ? $"{stats.MaxGroundSpeedKmh.Value:0.0}" : "—";

        return $"{avgText} / {maxText} km/h";
    }

    private static int? GetTakeoffHeight(FlightStats stats)
        => stats.AltBaroStart ?? stats.AltGpsStart;

    private static int? GetLandingHeight(FlightStats stats)
        => stats.AltBaroEnd ?? stats.AltGpsEnd;

    private static int? GetAltitudeMin(FlightStats stats)
        => stats.AltBaroMin ?? stats.AltGpsMin;

    private static int? GetAltitudeMax(FlightStats stats)
        => stats.AltBaroMax ?? stats.AltGpsMax;
}