@page "/flights/{Id}"

@using FlightApp.Analysis
@using FlightApp.Components
@using FlightApp.Domain
@using FlightApp.Services
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop

@implements IAsyncDisposable

@inject FlightService FlightService
@inject IJSRuntime JS

<div class="flight-details-page">
    @if (isLoading)
    {
        <div class="state-card">
            <div class="state-title">Loading flight…</div>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="state-card state-error">
            <div class="state-title">Could not load flight</div>
            <div class="state-text">@errorMessage</div>
        </div>
    }
    else if (flight is null)
    {
        <div class="state-card">
            <div class="state-title">Flight not found</div>
            <div class="state-text">No flight exists for the requested id.</div>
        </div>
    }
    else if (displayedStats is null)
    {
        <div class="state-card">
            <div class="state-title">Flight data incomplete</div>
            <div class="state-text">Statistics are not available.</div>
        </div>
    }
    else
    {

        @if (!showAllClimbs)
        {
            <div class="flight-header">
                <div class="flight-kpis-top">
                    <div class="hero-kpi @(currentSelection != null ? "hero-kpi-selection" : null)">
                        <div class="hero-kpi-label">@(SelectedClimb is null ? "Date / Time" : "Begin / End")</div>

                        <div class="hero-kpi-value">
                            @(SelectedClimb is null
                            ? FlightDetailsFormatters.FormatDateTimeShort(displayedStats.StartTimeUtc)
                            : FormatSelectedClimbBeginEnd())
                        </div>

                        <div class="hero-kpi-sub">
                            @(SelectedClimb is null
                            ? FlightDetailsFormatters.NullOrDash(flight.PilotId)
                            : "Relative flight time")
                        </div>
                    </div>

                    <div class="hero-kpi @(currentSelection != null ? "hero-kpi-selection" : null)">
                        <div class="hero-kpi-label">Duration</div>
                        <div class="hero-kpi-value">@FormatDisplayedDuration()</div>
                        <div class="hero-kpi-sub">@(SelectedClimb is null ? FlightDetailsFormatters.NullOrDash(flight.GliderId) : "Selected climb")
                        </div>
                    </div>

                    <div class="hero-kpi @(currentSelection != null ? "hero-kpi-selection" : null)">
                        <div class="hero-kpi-label">Distance</div>
                        <div class="hero-kpi-value">@FlightDetailsFormatters.FormatDistanceKm(displayedStats.TotalDistanceMeters)</div>
                        <div class="hero-kpi-sub">Fixes @displayedStats.FixCount</div>
                    </div>

                    <div class="hero-kpi @(currentSelection != null ? "hero-kpi-selection" : null)">
                        <div class="hero-kpi-label">Altitude</div>
                        <div class="hero-kpi-value">@FlightDetailsFormatters.FormatAltitudeMinMaxPreferred(displayedStats)</div>
                        <div class="hero-kpi-sub">Min / Max</div>
                    </div>

                    <div class="hero-kpi @(currentSelection != null ? "hero-kpi-selection" : null)">
                        <div class="hero-kpi-label">Vario</div>
                        <div class="hero-kpi-value">@FlightDetailsFormatters.FormatVario(displayedStats, SelectedClimb)</div>
                        <div class="hero-kpi-sub">@(SelectedClimb is null ? "Min / Max" : "Min / Max / Avg")</div>
                    </div>

                    <div class="hero-kpi @(currentSelection != null ? "hero-kpi-selection" : null)">
                        <div class="hero-kpi-label">Speed</div>
                        <div class="hero-kpi-value">@FlightDetailsFormatters.FormatSpeedAvgMax(displayedStats)</div>
                        <div class="hero-kpi-sub">Avg / Max</div>
                    </div>

                    <div class="hero-kpi @(currentSelection != null ? "hero-kpi-selection" : null)">
                        <div class="hero-kpi-label">@(SelectedClimb is null ? "Takeoff / Landing Elevation" : "Gain")</div>
                        <div class="hero-kpi-value">
                            @if (SelectedClimb is null)
                            {
                                @($"{FlightDetailsFormatters.FormatAltitudeValue(GetTakeoffHeight(displayedStats))} /                    {FlightDetailsFormatters.FormatAltitudeValue(GetLandingHeight(displayedStats))}")
                            }
                            else
                            {
                                @FlightDetailsFormatters.FormatGain(SelectedClimb)
                            }
                        </div>
                        <div class="hero-kpi-sub">@(SelectedClimb is null ? "m (start / land)" : "Net climb")</div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="flight-kpis-top">
                @foreach (var item in allClimbKpis)
                {
                    <div class="hero-kpi">
                        <div class="hero-kpi-label">@item.Label</div>

                        <div class="hero-kpi-value hero-kpi-minmax">
                            <span class="hero-kpi-side-label">Max</span>

                            <span class="hero-kpi-link" @onclick="@(() => SelectClimb(item.MaxClimbIndex))">
                                @item.MaxText
                            </span>

                            <span class="hero-kpi-separator">/</span>

                            <span class="hero-kpi-side-label">Min</span>

                            <span class="hero-kpi-link" @onclick="@(() => SelectClimb(item.MinClimbIndex))">
                                @item.MinText
                            </span>
                        </div>

                        <div class="hero-kpi-sub">@item.SubText</div>
                    </div>
                }
            </div>
        }
        @if (climbSegments.Count > 0)
        {
            <div class="climb-nav-row">
                <div class="climb-nav-shell">

                    <button type="button" class="climb-btn" title="Previous climb" @onclick="SelectPreviousClimb"
                            disabled="@(!CanSelectPreviousClimb)">
                        ◀
                    </button>

                    <div class="climb-info">
                        <div class="climb-title">@GetClimbNavigatorTitle()</div>
                        <div class="climb-sub">@GetClimbNavigatorSubtitle()</div>
                    </div>

                    <button type="button" class="climb-btn climb-btn-primary" title="Next climb" @onclick="SelectNextClimb"
                            disabled="@(!CanSelectNextClimb)">
                        ▶
                    </button>

                    <button type="button" class="climb-btn-clear" title="Clear selection" @onclick="ClearSelection"
                            disabled="@(!CanClear)">
                        ✕
                    </button>

                    <button type="button" class="climb-btn-toggle @(showAllClimbs ? "climb-btn-toggle-active" : null)"
                            title="Show all climbs" @onclick="ToggleShowAllClimbs">
                        All
                    </button>

                </div>
            </div>
        }

        <div class="flight-layout" @ref="flightLayoutRef">
            <div class="left-pane" style="@GetLeftPaneStyle()">
                <FlightCharts Track="trackArrays" SelectedClimb="SelectedClimb" ClimbSegments="climbSegments"
                              ShowAllClimbs="showAllClimbs" />
            </div>

            <div class="splitter @(isResizing ? "splitter-active" : null)" @onmousedown="StartResize"
                 @onmousedown:preventDefault="true" aria-label="Resize panels" role="separator">
            </div>

            <div class="right-pane">
                <FlightMap Track="trackArrays" Height="100%" />
            </div>
        </div>

        @if (isResizing)
        {
            <div class="resize-overlay"></div>
        }
    }
</div>

@code {
    [Parameter]
    public string? Id { get; set; }

    private readonly TrackSegmentStatsCalculator segmentStatsCalculator = new();

    private SelectionRange? currentSelection;
    private FlightStats? displayedStats;

    private Flight? flight;
    private TrackArrays? trackArrays;
    private List<ClimbSegment> climbSegments = new();
    private int? selectedClimbIndex;

    private bool isLoading;
    private string? errorMessage;

    private int leftPanePercent = 50;
    private bool isResizing;

    private ElementReference flightLayoutRef;
    private double layoutLeft;
    private double layoutWidth;

    private ClimbSummary? climbSummary;

    private List<ClimbSummaryKpi> allClimbKpis = new();

    private DotNetObjectReference<FlightDetails>? dotNetRef;


    private ClimbSegment? SelectedClimb
    => selectedClimbIndex.HasValue &&
    selectedClimbIndex.Value >= 0 &&
    selectedClimbIndex.Value < climbSegments.Count
    ? climbSegments[selectedClimbIndex.Value]
    : null;

    private bool CanSelectPreviousClimb
    => selectedClimbIndex.HasValue && selectedClimbIndex.Value > 0;

    private bool CanSelectNextClimb
    => climbSegments.Count > 0 &&
    (!selectedClimbIndex.HasValue || selectedClimbIndex.Value < climbSegments.Count - 1);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        dotNetRef ??= DotNetObjectReference.Create(this);

        await JS.InvokeVoidAsync("flightCharts.registerSelectionCallback", dotNetRef);
    }

    [JSInvokable]
    public Task OnChartSelection(int startIndex, int endIndex)
    {
        selectedClimbIndex = null;
        ApplySelection(startIndex, endIndex);
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnChartSelectionCleared()
    {
        ClearSelection();
        return Task.CompletedTask;
    }

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        errorMessage = null;
        flight = null;
        trackArrays = null;
        displayedStats = null;
        currentSelection = null;
        climbSegments = new List<ClimbSegment>();
        selectedClimbIndex = null;
        showAllClimbs = false;
        allClimbKpis = new List<ClimbSummaryKpi>();

        try
        {
            if (string.IsNullOrWhiteSpace(Id))
            {
                errorMessage = "Missing flight id.";
                return;
            }

            flight = await FlightService.GetFlightByIdAsync(Id);
            trackArrays = await FlightService.GetTrackAsync(Id);

            displayedStats = flight?.Stats;

            if (trackArrays is not null)
            {
                climbSegments = ClimbDetector.DetectClimbs(trackArrays);
                climbSummary = ComputeClimbSummary();
                allClimbKpis = BuildAllClimbKpis();
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    /// <summary>
    /// Computes min/max statistics across all climb segments.
    /// </summary>
    private ClimbSummary ComputeClimbSummary()
    {
        var summary = new ClimbSummary
        {
            Count = climbSegments.Count
        };

        for (int i = 0; i < climbSegments.Count; i++)
        {
            var climb = climbSegments[i];

            var duration = climb.DurationSec;
            var gain = climb.GainM;
            var avgClimb = climb.AvgClimbRateMs;
            var avgSpeed = climb.AvgSpeedKmh;
            var maxSpeed = climb.MaxSpeedKmh;

            if (summary.MaxDuration is null || duration > summary.MaxDuration.Value.value)
                summary.MaxDuration = (duration, i);

            if (summary.MinDuration is null || duration < summary.MinDuration.Value.value)
                summary.MinDuration = (duration, i);

            if (summary.MaxGain is null || gain > summary.MaxGain.Value.value)
                summary.MaxGain = (gain, i);

            if (summary.MinGain is null || gain < summary.MinGain.Value.value)
                summary.MinGain = (gain, i);

            if (summary.MaxAvgClimb is null || avgClimb > summary.MaxAvgClimb.Value.value)
                summary.MaxAvgClimb = (avgClimb, i);

            if (summary.MinAvgClimb is null || avgClimb < summary.MinAvgClimb.Value.value)
                summary.MinAvgClimb = (avgClimb, i);

            if (summary.MaxAvgSpeed is null || avgSpeed > summary.MaxAvgSpeed.Value.value)
                summary.MaxAvgSpeed = (avgSpeed, i);

            if (summary.MinAvgSpeed is null || avgSpeed < summary.MinAvgSpeed.Value.value)
                summary.MinAvgSpeed = (avgSpeed, i);

            if (summary.MaxSpeed is null || maxSpeed > summary.MaxSpeed.Value.value)
                summary.MaxSpeed = (maxSpeed, i);



            var selection = new SelectionRange(climb.BeginIndex, climb.EndIndex);
            FlightStats? stats = trackArrays is not null
                ? segmentStatsCalculator.Calculate(trackArrays, selection)
                : null;

            var maxClimb = stats?.MaxVarioMs;
            var minClimb = stats?.MinVarioMs;

            if (maxClimb.HasValue)
            {
                if (summary.MaxClimb is null || maxClimb.Value > summary.MaxClimb.Value.value)
                    summary.MaxClimb = (maxClimb.Value, i);
            }

            if (minClimb.HasValue)
            {
                if (summary.MinClimb is null || minClimb.Value < summary.MinClimb.Value.value)
                    summary.MinClimb = (minClimb.Value, i);
            }
        }

        return summary;
    }

    private void ApplySelection(int startIndex, int endIndex)
    {
        if (trackArrays is null)
            return;

        var selection = new SelectionRange(startIndex, endIndex);
        if (!selection.IsValid)
            return;

        currentSelection = selection;
        displayedStats = segmentStatsCalculator.Calculate(trackArrays, selection);

        StateHasChanged();
    }

    private void ClearSelection()
    {
        selectedClimbIndex = null;
        currentSelection = null;
        showAllClimbs = false;
        displayedStats = flight?.Stats;

        StateHasChanged();
    }

    private void SelectPreviousClimb()
    {
        if (!CanSelectPreviousClimb)
            return;

        SelectClimb(selectedClimbIndex!.Value - 1);
    }

    private void SelectNextClimb()
    {
        if (climbSegments.Count == 0)
            return;

        if (!selectedClimbIndex.HasValue)
        {
            SelectClimb(0);
            return;
        }

        if (selectedClimbIndex.Value >= climbSegments.Count - 1)
            return;

        SelectClimb(selectedClimbIndex.Value + 1);
    }

    private void SelectClimb(int index)
    {
        if (index < 0 || index >= climbSegments.Count)
            return;

        selectedClimbIndex = index;

        var climb = climbSegments[index];
        ApplySelection(climb.BeginIndex, climb.EndIndex);
    }

    private string GetLeftPaneStyle()
    => $"flex: 0 0 {leftPanePercent}%";

    private async Task StartResize(MouseEventArgs _)
    {
        dotNetRef ??= DotNetObjectReference.Create(this);
        isResizing = true;
        await InvokeAsync(StateHasChanged);

        await JS.InvokeVoidAsync("flightDetails.startResize", flightLayoutRef, dotNetRef);
    }

    [JSInvokable]
    public Task SetResizeBounds(double left, double width)
    {
        layoutLeft = left;
        layoutWidth = width;
        return Task.CompletedTask;
    }

    [JSInvokable]
    public async Task OnResizeDrag(double clientX)
    {
        if (layoutWidth <= 0)
            return;

        var relativeX = clientX - layoutLeft;
        var newPercent = (int)Math.Round(relativeX / layoutWidth * 100.0);

        var clamped = Math.Clamp(newPercent, 30, 75);
        if (clamped == leftPanePercent)
            return;

        leftPanePercent = clamped;

        await InvokeAsync(StateHasChanged);
        await JS.InvokeVoidAsync("flightDetails.notifyResize");
    }

    [JSInvokable]
    public async Task OnResizeEnd()
    {
        isResizing = false;
        await InvokeAsync(StateHasChanged);
        await JS.InvokeVoidAsync("flightDetails.notifyResize");
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("flightCharts.clearSelectionCallback");
        }
        catch
        {
        }

        dotNetRef?.Dispose();
    }

    private string GetClimbNavigatorTitle()
    {
        if (climbSegments.Count == 0)
            return "No climbs";

        if (!selectedClimbIndex.HasValue)
            return $"Climb — / {climbSegments.Count}";

        return $"Climb {selectedClimbIndex.Value + 1} / {climbSegments.Count}";
    }

    private string GetClimbNavigatorSubtitle()
    {
        if (climbSegments.Count == 0)
            return string.Empty;

        var climb = SelectedClimb;
        if (climb is null)
            return $"{climbSegments.Count} climbs detected";

        return $"{FlightDetailsFormatters.FormatGain(climb)} · {climb.AvgClimbRateMs:0.0} m/s";
    }

    /// <summary>
    /// Returns the relative flight time in seconds for a given track index
    /// using the precomputed TimeSec array.
    /// </summary>
    private int GetTrackTimeSeconds(int index)
    {
        if (trackArrays?.TimeSec is null || trackArrays.TimeSec.Length == 0)
            return 0;

        if (index < 0)
            return 0;

        if (index >= trackArrays.TimeSec.Length)
            index = trackArrays.TimeSec.Length - 1;

        return trackArrays.TimeSec[index];
    }

    /// <summary>
    /// Returns a formatted "Begin / End" time string for the selected climb.
    /// Times are read from the precomputed TimeSec array.
    /// </summary>
    private string FormatSelectedClimbBeginEnd()
    {
        var climb = SelectedClimb;

        if (climb is null || trackArrays?.TimeSec is null)
            return "— / —";

        var begin = GetTrackTimeSeconds(climb.BeginIndex);
        var end = GetTrackTimeSeconds(climb.EndIndex);

        return $"{FlightDetailsFormatters.FormatClockFromSeconds(begin)} / {FlightDetailsFormatters.FormatClockFromSeconds(end)}";
    }

    /// <summary>
    /// Returns the duration displayed in the Duration KPI.
    /// If a climb is selected, the climb duration is calculated from TimeSec.
    /// Otherwise the normal flight duration is used.
    /// </summary>
    private string FormatDisplayedDuration()
    {
        var climb = SelectedClimb;

        if (climb is not null && trackArrays?.TimeSec is not null)
        {
            var begin = GetTrackTimeSeconds(climb.BeginIndex);
            var end = GetTrackTimeSeconds(climb.EndIndex);

            var durationSeconds = Math.Max(0, end - begin);

            return FlightDetailsFormatters.FormatClockFromSeconds(durationSeconds);
        }

        if (displayedStats is null)
            return "—";

        return FlightDetailsFormatters.FormatDuration(displayedStats.Duration);
    }

    /// <summary>
    /// Builds compact KPI cards for the all-climbs mode.
    /// Each card shows a max/min pair and allows clicking either side
    /// to select the corresponding climb.
    /// </summary>
    private List<ClimbSummaryKpi> BuildAllClimbKpis()
    {
        var items = new List<ClimbSummaryKpi>();

        if (climbSummary is null || climbSummary.Count == 0)
            return items;

        if (climbSummary.MaxDuration is { } maxDuration &&
            climbSummary.MinDuration is { } minDuration)
        {
            items.Add(new ClimbSummaryKpi
            {
                Label = "Duration",
                MaxText = FlightDetailsFormatters.FormatDurationSeconds(maxDuration.value),
                MaxClimbIndex = maxDuration.index,
                MinText = FlightDetailsFormatters.FormatDurationSeconds(minDuration.value),
                MinClimbIndex = minDuration.index,
                SubText = "Max / Min"
            });
        }

        if (climbSummary.MaxGain is { } maxGain &&
            climbSummary.MinGain is { } minGain)
        {
            items.Add(new ClimbSummaryKpi
            {
                Label = "Gain",
                MaxText = FlightDetailsFormatters.FormatMeters(maxGain.value),
                MaxClimbIndex = maxGain.index,
                MinText = FlightDetailsFormatters.FormatMeters(minGain.value),
                MinClimbIndex = minGain.index,
                SubText = "Max / Min"
            });
        }

        if (climbSummary.MaxAvgClimb is { } maxAvgClimb &&
            climbSummary.MinAvgClimb is { } minAvgClimb)
        {
            items.Add(new ClimbSummaryKpi
            {
                Label = "Avg Climb",
                MaxText = FlightDetailsFormatters.FormatMs(maxAvgClimb.value),
                MaxClimbIndex = maxAvgClimb.index,
                MinText = FlightDetailsFormatters.FormatMs(minAvgClimb.value),
                MinClimbIndex = minAvgClimb.index,
                SubText = "Max / Min"
            });
        }

        if (climbSummary.MaxAvgSpeed is { } maxAvgSpeed &&
            climbSummary.MinAvgSpeed is { } minAvgSpeed)
        {
            items.Add(new ClimbSummaryKpi
            {
                Label = "Avg Speed",
                MaxText = FlightDetailsFormatters.FormatKmh(maxAvgSpeed.value),
                MaxClimbIndex = maxAvgSpeed.index,
                MinText = FlightDetailsFormatters.FormatKmh(minAvgSpeed.value),
                MinClimbIndex = minAvgSpeed.index,
                SubText = "Max / Min"
            });
        }

        if (climbSummary.MaxClimb is { } maxClimb &&
            climbSummary.MinClimb is { } minClimb)
        {
            items.Add(new ClimbSummaryKpi
            {
                Label = "Climb",
                MaxText = FlightDetailsFormatters.FormatMs(maxClimb.value),
                MaxClimbIndex = maxClimb.index,
                MinText = FlightDetailsFormatters.FormatMs(minClimb.value),
                MinClimbIndex = minClimb.index,
                SubText = "Max / Min"
            });
        }

        return items;
    }

    private static int? GetTakeoffHeight(FlightStats stats)
    => stats.AltBaroStart ?? stats.AltGpsStart;

    private static int? GetLandingHeight(FlightStats stats)
    => stats.AltBaroEnd ?? stats.AltGpsEnd;

    private bool CanClear
    => currentSelection is not null || selectedClimbIndex is not null || showAllClimbs;

    private bool showAllClimbs;


    private void ToggleShowAllClimbs()
    {
        showAllClimbs = !showAllClimbs;
    }
}