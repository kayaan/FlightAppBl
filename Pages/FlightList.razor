@page "/"
@page "/flights"

@using FlightApp.Components
@using FlightApp.Domain
@using FlightApp.Services
@using Microsoft.AspNetCore.Components.Forms

@inject IJSRuntime JS

@inject FlightService FlightService


<h1>Flights</h1>

<button @onclick="OpenImport">
    Import IGC
</button>
<InputFile @ref="fileInput" OnChange="HandleFileSelected" style="display: none;" accept=".igc" multiple />

@if (flights.Count == 0)
{
    <p>No flights imported.</p>
}
else
{
    <table style="margin-top:20px; width:100%; border-collapse:collapse">
        <thead>
            <tr style="border-bottom:2px solid #ccc">
                <th>Date</th>
                <th>Pilot</th>
                <th>Glider</th>
                <th>Fixes</th>
                <th>Duration</th>
                <th>Distance km</th>
                <th>Max Alt GPS</th>
                <th>Max Alt Baro</th>
                <th>Avg Speed</th>
                <th>Max Speed</th>
                <th>Avg Vario</th>
                <th>Climb</th>
                <th>Sink</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var f in flights)
            {
                <tr style="border-bottom:1px solid #eee">
                    <td>@f.Date</td>
                    <td>@f.PilotId</td>
                    <td>@f.GliderId</td>
                    <td>@f.Stats.FixCount</td>
                    <td>@f.Stats.Duration</td>
                    <td>@(Math.Round(f.Stats.TotalDistanceMeters / 1000.0, 1))</td>
                    <td>@f.Stats.AltGpsMax</td>
                    <td>@f.Stats.AltBaroMax</td>
                    <td>@(f.Stats.AvgGroundSpeedKmh?.ToString("F1"))</td>
                    <td>@(f.Stats.MaxGroundSpeedKmh?.ToString("F1"))</td>
                    <td>@(f.Stats.AvgVarioMs?.ToString("F2"))</td>
                    <td>@Math.Round(f.Stats.TotalClimbMeters, 0)</td>
                    <td>@Math.Round(f.Stats.TotalSinkMeters, 0)</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {

    private InputFile? fileInput;
    private List<Flight> flights = new();

    protected override async Task OnInitializedAsync()
    {
        flights = await FlightService.GetFlightsAsync();
    }


    private async Task OpenImport()
    {
        if (fileInput is not null)
        {
            await JS.InvokeVoidAsync("openFilePicker", fileInput.Element);
        }
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var files = e.GetMultipleFiles();
        var contents = new List<string>();

        foreach (var file in files)
        {
            using var stream = file.OpenReadStream();
            using var reader = new StreamReader(stream);

            contents.Add(await reader.ReadToEndAsync());
        }

        await FlightService.ImportFilesAsync(contents);

        flights = await FlightService.GetFlightsAsync();
    }
}