@using FlightApp.Domain

@if (Fixes == null || Fixes.Count < 2)
{
    <p>No altitude data.</p>
}
else
{
    <svg width="@Width" height="@Height" viewBox="0 0 @Width @Height" style="border:1px solid #ccc; background:#fff;">
        <polyline
            fill="none"
            stroke="steelblue"
            stroke-width="2"
            points="@BuildPoints()" />
    </svg>
}

@code {
    [Parameter] public List<FixPoint>? Fixes { get; set; }

    [Parameter] public int Width { get; set; } = 900;
    [Parameter] public int Height { get; set; } = 250;

    private string BuildPoints()
    {
        if (Fixes == null || Fixes.Count < 2)
            return string.Empty;

        var values = Fixes
            .Select(f => (double?)f.AltitudeBaro ?? f.AltitudeGps)
            .Where(a => a.HasValue)
            .Select(a => a!.Value)
            .ToList();

        if (values.Count < 2)
            return string.Empty;

        var minAlt = values.Min();
        var maxAlt = values.Max();
        var range = maxAlt - minAlt;

        if (range <= 0)
            range = 1;

        var chartPadding = 10.0;
        var usableWidth = Width - 2 * chartPadding;
        var usableHeight = Height - 2 * chartPadding;

        var points = new List<string>();

        for (int i = 0; i < Fixes.Count; i++)
        {
            var alt = (double?)Fixes[i].AltitudeBaro ?? Fixes[i].AltitudeGps;
            if (!alt.HasValue)
                continue;

            var x = chartPadding + (i / (double)(Fixes.Count - 1)) * usableWidth;

            // SVG y=0 ist oben, deshalb invertieren
            var y = chartPadding + (1.0 - ((alt.Value - minAlt) / range)) * usableHeight;

            points.Add($"{x:F1},{y:F1}");
        }

        return string.Join(" ", points);
    }
}